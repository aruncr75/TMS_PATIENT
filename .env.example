# ── API ────────────────────────────────────────────────────────────────────────
# REST base URL. In dev, leave as /api — Vite proxies /api/* → http://localhost:3000/*
# (see vite.config.ts). In production, set to the deployed backend origin.
VITE_API_URL=/api

# ── WebSocket (live queue, Phase 5) ─────────────────────────────────────────────
# Socket.IO connects to the backend ORIGIN directly (default path /socket.io,
# namespace /queue). The /api Vite proxy does NOT cover the socket, so this must
# point at the backend origin, not the proxy path.
VITE_WS_URL=http://localhost:3000

# ── Firebase Cloud Messaging (web push, Phase 7) ────────────────────────────────
# From the Firebase console → Project settings → General (web app config) and
# Cloud Messaging (Web Push certificates → VAPID key pair).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
